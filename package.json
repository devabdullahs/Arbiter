{
  "name": "esports-admin-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Discord.js esports referee and admin workflow bot.",
  "license": "PolyForm-Noncommercial-1.0.0",
  "author": "Abdullah (@devabdullahs)",
  "homepage": "https://github.com/devabdullahs/esports-admin-bot#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/devabdullahs/esports-admin-bot.git"
  },
