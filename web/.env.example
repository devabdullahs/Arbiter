# --- Database (shared with the bot) ---
DATABASE_URL="postgresql://esports:esports@localhost:5432/esports_admin_bot?schema=public"

# --- Better Auth ---
# Generate a strong secret, e.g.: npx @better-auth/cli secret
BETTER_AUTH_SECRET=""
# Public base URL of the dashboard.
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="https://arbiter.moonbot.info"
NEXT_PUBLIC_GA_ID=""

# --- Discord OAuth (reuse the bot's Discord application) ---
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
# In the Discord Developer Portal -> OAuth2, add this redirect URL:
#   http://localhost:3000/api/auth/callback/discord

# --- Email (magic link + OTP) via Resend ---
# Create an API key at https://resend.com and verify a sending domain.
# Without RESEND_API_KEY, development prints links/codes to the server console.
RESEND_API_KEY=""
# Sender address - must be on a verified Resend domain. The default test sender
# below only delivers to your own Resend account's email address.
EMAIL_FROM="Arbiter <onboarding@resend.dev>"
