generator client {
  provider = "prisma-client-js"
}

// Second client for the web dashboard (web/). Self-contained output so the
// dashboard can import its own generated client without disturbing the bot's
// default @prisma/client. Both are generated from this single schema.
generator web {
  provider = "prisma-client-js"
  output   = "../web/lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Better Auth (web dashboard authentication).
// Generated by `@better-auth/cli generate`. These back the dashboard's login
// (Discord OAuth + passwordless email magic link/OTP) and account linking.
// The bot does not use these tables; dashboard authz maps the linked Discord
// account id to UserProfile.discordUserId -> OrgMember.
// ---------------------------------------------------------------------------

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          String?
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?
  sessions      Session[]
  accounts      Account[]
  passkeys      Passkey[]

  @@unique([email])
  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Passkey {
  id           String    @id
  name         String?
  publicKey    String
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialID String
  counter      Int
  deviceType   String
  backedUp     Boolean
  transports   String?
  createdAt    DateTime?
  lastUsedAt   DateTime?
  aaguid       String?

  @@index([userId])
  @@index([credentialID])
  @@map("passkey")
}

enum OrgMemberRole {
  OWNER
  ADMIN
  REFEREE
  PLAYER
}

enum MatchStatus {
  PENDING
  VETO
  LIVE
  DISPUTED
  COMPLETE
  CANCELLED
}

enum VetoKind {
  BAN
  PICK
}

model Organization {
  id              String              @id @default(cuid())
  discordGuildId  String              @unique
  name            String
  settings        OrgSettings?
  members         OrgMember[]
  tournaments     Tournament[]
  teams           Team[]
  matches         Match[]
  scoreReports    ScoreReport[]
  rosterEntries   RosterSubmission[]
  reminders       ScheduledReminder[]
  rulebook        RulebookEntry[]
  shifts          RefereeShift[]
  auditLogs       AuditLog[]
  rulesPresets    RulesPreset[]
  brLobbies       BrLobby[]
  invites         OrgInvite[]
  discordSyncJobs DiscordSyncJob[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

// Dashboard email invites: invite someone to an org by email. Accepted by
// mapping the invitee's linked Discord account to a UserProfile + OrgMember.
model OrgInvite {
  id             String        @id @default(cuid())
  organizationId String
  email          String
  role           OrgMemberRole @default(REFEREE)
  token          String        @unique
  status         String        @default("pending") // pending | accepted | revoked
  invitedById    String?
  acceptedById   String?
  expiresAt      DateTime
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId])
  @@index([email])
}

model RulesPreset {
  id             String       @id @default(cuid())
  organizationId String
  key            String
  label          String
  mapPool        Json
  vetoMode       String       @default("final_map_ban")
  notes          String?
  createdById    String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, key])
  @@index([organizationId])
}

// Battle-royale lobby: N teams scored across multiple games by placement + kill points.
model BrLobby {
  id               String         @id @default(cuid())
  publicCode       String         @unique
  organizationId   String
  channelId        String?
  controlMessageId String?
  createdById      String?
  name             String
  game             String
  status           MatchStatus    @default(PENDING)
  gamesPlanned     Int            @default(6)
  killPoints       Int            @default(1)
  placementPoints  Json
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teams            BrTeam[]
  results          BrGameResult[]
  adjustments      BrAdjustment[]
  logs             BrLog[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([organizationId])
}

model BrTeam {
  id                String         @id @default(cuid())
  lobbyId           String
  name              String
  seed              Int?
  discordRoleId     String?
  categoryChannelId String?
  textChannelId     String?
  voiceChannelId    String?
  teamMessageId     String?
  lobby             BrLobby        @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  results           BrGameResult[]
  adjustments       BrAdjustment[]
  logs              BrLog[]
  createdAt         DateTime       @default(now())

  @@unique([lobbyId, name])
  @@index([lobbyId])
}

// Referee point/kill adjustments and penalties — included in standings totals.
model BrAdjustment {
  id         String   @id @default(cuid())
  lobbyId    String
  brTeamId   String
  points     Int      @default(0)
  kills      Int      @default(0)
  gameNumber Int?
  reason     String
  actorId    String?
  lobby      BrLobby  @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  team       BrTeam   @relation(fields: [brTeamId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([lobbyId])
}

// Referee log for a lobby: pauses, warnings, evidence, notes, disputes.
model BrLog {
  id              String   @id @default(cuid())
  lobbyId         String
  kind            String
  brTeamId        String?
  subject         String?
  gameNumber      Int?
  summary         String?
  details         String?
  rule            String?
  durationMinutes Int?
  attachmentUrl   String?
  attachmentName  String?
  actorId         String?
  lobby           BrLobby  @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  team            BrTeam?  @relation(fields: [brTeamId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())

  @@index([lobbyId])
}

model BrGameResult {
  id         String   @id @default(cuid())
  lobbyId    String
  brTeamId   String
  gameNumber Int
  placement  Int
  kills      Int
  points     Int
  actorId    String?
  lobby      BrLobby  @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  team       BrTeam   @relation(fields: [brTeamId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([lobbyId, brTeamId, gameNumber])
  @@index([lobbyId])
}

model OrgSettings {
  id                String       @id @default(cuid())
  organizationId    String       @unique
  adminRoleId       String?
  refereeRoleId     String?
  matchCategoryId   String?
  matchLogChannelId String?
  evidenceChannelId String?
  webPermissions    Json?
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model OrgMember {
  id             String        @id @default(cuid())
  organizationId String
  userProfileId  String
  role           OrgMemberRole @default(PLAYER)
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userProfile    UserProfile   @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([organizationId, userProfileId])
  @@index([userProfileId])
}

model UserProfile {
  id                      String                     @id @default(cuid())
  discordUserId           String                     @unique
  displayName             String?
  countryCode             String?
  bio                     String?
  profileVisibility       String                     @default("private")
  openToWork              Boolean                    @default(false)
  avatarUrl               String?
  avatarMimeType          String?
  avatarSizeBytes         Int?
  avatarUpdatedAt         DateTime?
  contactEmail            String?
  showContactEmail        Boolean                    @default(false)
  socialLinks             Json?
  gameExperiences         String[]                   @default([])
  fieldRoles              String[]                   @default([])
  linkedAccounts          LinkedAccount[]
  memberships             OrgMember[]
  teamMembers             TeamMember[]
  captainedTeams          Team[]                     @relation("TeamCaptain")
  workerFavorites         WorkerFavorite[]           @relation("WorkerFavoriteOwner")
  savedByProfiles         WorkerFavorite[]           @relation("WorkerFavoriteWorker")
  sentProfileRequests     ProfileConnectionRequest[] @relation("ProfileConnectionRequester")
  receivedProfileRequests ProfileConnectionRequest[] @relation("ProfileConnectionTarget")
  checkins                Checkin[]
  pauseLogs               PauseLog[]
  warningsIssued          Warning[]                  @relation("WarningIssuer")
  evidence                Evidence[]
  shifts                  RefereeShift[]
  auditLogs               AuditLog[]
  standaloneLogs          StandaloneLog[]
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt
}

model WorkerFavorite {
  id        String      @id @default(cuid())
  ownerId   String
  workerId  String
  priority  Boolean     @default(false)
  note      String?
  owner     UserProfile @relation("WorkerFavoriteOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  worker    UserProfile @relation("WorkerFavoriteWorker", fields: [workerId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([ownerId, workerId])
  @@index([workerId])
}

model ProfileConnectionRequest {
  id          String      @id @default(cuid())
  requesterId String
  targetId    String
  status      String      @default("pending")
  message     String?
  requester   UserProfile @relation("ProfileConnectionRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  target      UserProfile @relation("ProfileConnectionTarget", fields: [targetId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([requesterId, targetId])
  @@index([targetId])
}

// Matchless logs captured by referees via the user-installed /log command, e.g. for
// external tournaments where the bot is not present and no match record exists.
model StandaloneLog {
  id             String      @id @default(cuid())
  userProfileId  String
  kind           String
  event          String?
  teams          String?
  subject        String?
  summary        String?
  details        String?
  result         String?
  attachmentUrl  String?
  attachmentName String?
  userProfile    UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  createdAt      DateTime    @default(now())

  @@index([userProfileId])
}

model LinkedAccount {
  id            String      @id @default(cuid())
  userProfileId String
  provider      String
  handle        String
  metadata      Json?
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([provider, handle])
  @@index([userProfileId])
}

model Tournament {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  gameTitle      String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  matches        Match[]
  teams          Team[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Team {
  id               String             @id @default(cuid())
  organizationId   String
  tournamentId     String?
  name             String
  captainProfileId String?
  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tournament       Tournament?        @relation(fields: [tournamentId], references: [id], onDelete: SetNull)
  captain          UserProfile?       @relation("TeamCaptain", fields: [captainProfileId], references: [id], onDelete: SetNull)
  members          TeamMember[]
  participants     MatchParticipant[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([organizationId])
  @@index([captainProfileId])
}

model TeamMember {
  id            String       @id @default(cuid())
  teamId        String
  userProfileId String?
  displayName   String
  team          Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userProfile   UserProfile? @relation(fields: [userProfileId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Match {
  id                 String              @id @default(cuid())
  publicCode         String              @unique
  organizationId     String
  tournamentId       String?
  channelId          String?
  controlMessageId   String?
  createdById        String?
  teamAName          String
  teamBName          String
  bestOf             Int
  rulesPreset        String              @default("generic")
  vetoMode           String              @default("final_map_ban")
  mapPool            Json
  status             MatchStatus         @default(PENDING)
  teamAScore         Int                 @default(0)
  teamBScore         Int                 @default(0)
  allowPlayerReports Boolean             @default(false)
  assignedRefereeId  String?
  disputeReason      String?
  teamARoleId        String?
  teamBRoleId        String?
  rosterLockedAt     DateTime?
  rosterLockedById   String?
  finalMap           String?
  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tournament         Tournament?         @relation(fields: [tournamentId], references: [id], onDelete: SetNull)
  participants       MatchParticipant[]
  vetoActions        VetoAction[]
  checkins           Checkin[]
  pauseLogs          PauseLog[]
  warnings           Warning[]
  evidence           Evidence[]
  scoreReports       ScoreReport[]
  rosterSubmissions  RosterSubmission[]
  reminders          ScheduledReminder[]
  room               MatchRoom?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([organizationId])
  @@index([status])
}

model MatchParticipant {
  id      String @id @default(cuid())
  matchId String
  teamId  String
  slot    String
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team    Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([matchId, slot])
}

model VetoAction {
  id        String   @id @default(cuid())
  matchId   String
  kind      VetoKind
  teamSlot  String
  mapName   String
  actorId   String?
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([matchId])
}

model RefereeShift {
  id             String       @id @default(cuid())
  organizationId String
  userProfileId  String
  onShift        Boolean      @default(false)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userProfile    UserProfile  @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, userProfileId])
}

model Checkin {
  id             String      @id @default(cuid())
  organizationId String
  matchId        String
  userProfileId  String
  gameAccount    String
  validation     Json?
  match          Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userProfile    UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  createdAt      DateTime    @default(now())

  @@index([organizationId])
  @@index([userProfileId])
}

model PauseLog {
  id              String       @id @default(cuid())
  organizationId  String
  matchId         String
  pauseType       String       @default("team")
  teamName        String?
  durationMinutes Int
  reason          String
  actorId         String?
  match           Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  actor           UserProfile? @relation(fields: [actorId], references: [id], onDelete: SetNull)
  createdAt       DateTime     @default(now())

  @@index([organizationId])
}

model Warning {
  id             String       @id @default(cuid())
  organizationId String
  matchId        String
  teamName       String?
  player         String
  rule           String
  note           String?
  actorId        String?
  match          Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  actor          UserProfile? @relation("WarningIssuer", fields: [actorId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())

  @@index([organizationId])
}

model Evidence {
  id             String       @id @default(cuid())
  organizationId String
  matchId        String
  url            String
  note           String?
  status         String       @default("submitted")
  reviewedById   String?
  reviewedAt     DateTime?
  reviewNote     String?
  submittedById  String?
  match          Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  submittedBy    UserProfile? @relation(fields: [submittedById], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())

  @@index([organizationId])
}

model ScoreReport {
  id             String       @id @default(cuid())
  organizationId String
  matchId        String
  teamAScore     Int
  teamBScore     Int
  scoringType    String       @default("match")
  comment        String?
  attachments    Json?
  status         String       @default("pending")
  submittedById  String?
  reviewedById   String?
  reviewedAt     DateTime?
  reviewNote     String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  match          Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([matchId])
  @@index([status])
}

model RosterSubmission {
  id             String       @id @default(cuid())
  organizationId String
  matchId        String
  teamSlot       String
  teamName       String
  players        Json
  status         String       @default("submitted")
  note           String?
  submittedById  String?
  reviewedById   String?
  reviewedAt     DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  match          Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([matchId, teamSlot])
  @@index([organizationId])
  @@index([status])
}

model ScheduledReminder {
  id             String       @id @default(cuid())
  organizationId String
  matchId        String?
  kind           String
  dueAt          DateTime
  channelId      String?
  userId         String?
  payload        Json?
  deliveredAt    DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  match          Match?       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@index([dueAt])
  @@index([deliveredAt])
}

model RulebookEntry {
  id             String       @id @default(cuid())
  organizationId String
  key            String
  title          String
  body           String
  tags           String?
  createdById    String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, key])
  @@index([organizationId])
}

model MatchRoom {
  id                  String   @id @default(cuid())
  matchId             String   @unique
  textChannelId       String?
  voiceChannelId      String?
  categoryId          String?
  playerMessageId     String?
  teamATextChannelId  String?
  teamAVoiceChannelId String?
  teamAMessageId      String?
  teamBTextChannelId  String?
  teamBVoiceChannelId String?
  teamBMessageId      String?
  match               Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  actorId        String?
  action         String
  targetType     String?
  targetId       String?
  metadata       Json?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor          UserProfile? @relation(fields: [actorId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())

  @@index([organizationId])
}

model DiscordSyncJob {
  id             String       @id @default(cuid())
  organizationId String
  targetType     String
  targetId       String
  action         String       @default("refresh")
  status         String       @default("pending")
  attempts       Int          @default(0)
  lastError      String?
  claimedAt      DateTime?
  completedAt    DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([status, createdAt])
  @@index([organizationId])
  @@index([targetType, targetId])
}
