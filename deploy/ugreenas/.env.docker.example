# IMPORTANT: this password is embedded in DATABASE_URL, so use ONLY URL-safe
# characters: letters, digits, - and _ . Do NOT use / : @ # ? % & or spaces
# (they break URL parsing -> "invalid port number in database URL"), and avoid
# $ in any value here (Compose treats it as a variable -> "$X is not set").
POSTGRES_PASSWORD=replace-with-a-long-url-safe-password

# Container images. Defaults pull the CI-published images from GHCR
# (recommended). Override to a specific commit (…:<sha>) to pin, or to
# arbiter-bot:local / arbiter-web:local to use images you loaded from tarballs.
# ARBITER_BOT_IMAGE=ghcr.io/devabdullahs/arbiter-bot:latest
# ARBITER_WEB_IMAGE=ghcr.io/devabdullahs/arbiter-web:latest

ARBITER_WEB_PORT=3000
ARBITER_WEB_IPV4=10.69.2.52
MACVLAN_NETWORK=macvlan

DISCORD_TOKEN=replace-with-your-bot-token
DISCORD_CLIENT_ID=replace-with-your-discord-client-id
DISCORD_CLIENT_SECRET=replace-with-your-discord-client-secret
DISCORD_DEV_GUILD_ID=

BETTER_AUTH_URL=http://10.69.2.52:3000
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
NEXT_PUBLIC_SITE_URL=https://arbiter.moonbot.info
NEXT_PUBLIC_GA_ID=

RESEND_API_KEY=
EMAIL_FROM=Arbiter <noreply@example.com>

DEPLOY_DISCORD_COMMANDS=true
DISCORD_SYNC_INTERVAL_MS=5000
